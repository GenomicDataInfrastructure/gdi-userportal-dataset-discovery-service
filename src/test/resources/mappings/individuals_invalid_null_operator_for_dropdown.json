{
    "priority": 1,
    "request": {
        "method": "POST",
        "url": "/v2.0.0/individuals",
        "bodyPatterns": [
            {
                "matchesJsonPath": "$.query.filters[?(@.id == 'NCIT:C16576')]"
            },
            {
                "matches": "(?s).*\\\"operator\\\"\\s*:\\s*null.*"
            }
        ]
    },
    "response": {
        "status": 422,
        "headers": {
            "Content-Type": "application/json"
        },
        "jsonBody": {
            "error": "Invalid request payload: null operator is not allowed for this filter"
        }
    }
}
